<section class="section install-section" id="install">
  <div class="site-shell install-panel">
    <div class="section-header" style="margin-bottom:36px;text-align:left">
      <span class="section-number">05</span>
      <div>
        <p class="section-kicker">Install</p>
        <h2 class="section-title">Inspect the source first. Then install.</h2>
        <p class="section-copy">
          Read the code. Verify the checksum. Understand what you're running. No accounts, no cloud, no telemetry.
        </p>
      </div>
    </div>

    <div class="terminal-block" data-reveal>
      <div class="terminal-bar">
        <span class="terminal-dot"></span>
        <span class="terminal-dot"></span>
        <span class="terminal-dot"></span>
        <span class="terminal-title">PowerShell</span>
        <button class="terminal-copy" type="button" data-copy-trigger aria-label="Copy install command">Copy</button>
      </div>
      <div class="terminal-body">
        <div class="terminal-prompt" data-copy-trigger>
          <span class="prompt-sign">PS&gt;</span>
          <span class="prompt-cmd">irm https://raw.githubusercontent.com/TheUser99-spec/Phylax/main/install.ps1 | iex</span>
        </div>
        <div class="terminal-footnote">No admin required. The daemon runs in the background.</div>
      </div>
      <span class="copy-toast" data-copy-toast aria-live="polite">Copied</span>
    </div>

    <div class="docs-note" style="margin-bottom:24px" data-reveal>
      <strong>&#9888;&#65039; Before you run the installer</strong>
      <p style="margin-top:4px">1. <a href="https://raw.githubusercontent.com/TheUser99-spec/Phylax/main/install.ps1" target="_blank" rel="noreferrer" style="color:var(--blue)">Inspect the installer script</a> on GitHub &mdash; it's a single PowerShell file.</p>
      <p>2. <strong>Verify the checksum</strong> before execution:</p>
      <div class="code-block" style="margin:8px 0">
        <pre style="padding:12px 16px"><code style="font-size:12px;white-space:pre-wrap;word-break:break-all"># SHA256 of install.ps1
Get-FileHash install.ps1 -Algorithm SHA256</code></pre>
      </div>
      <p style="font-size:13px;color:var(--faint);margin-top:4px">Checksums are published with each <a href="https://github.com/TheUser99-spec/Phylax/releases" target="_blank" rel="noreferrer" style="color:var(--blue)">GitHub release</a>.</p>
    </div>

    <div class="docs-note" data-reveal>
      <strong>&#128736;&#65039; Manual install (build from source)</strong>
      <p style="margin-top:4px">Prefer to compile yourself? No problem.</p>
      <div class="code-block" style="margin:8px 0">
        <pre style="padding:12px 16px"><code style="font-size:12px">git clone https://github.com/TheUser99-spec/Phylax.git
cd Phylax
cargo build --workspace --release</code></pre>
      </div>
      <p style="font-size:13px;color:var(--faint);margin-top:4px">Requires Rust toolchain. The compiled binary will be in <code>target/release/</code>.</p>
    </div>

    <div class="quick-cmds" data-reveal>
      <div class="quick-cmd">
        <code>phylax init</code>
        <span>Creates phylax.toml and starts the daemon</span>
      </div>
      <div class="quick-cmd">
        <code>phylax run</code>
        <span>Daemon + live terminal dashboard (60fps)</span>
      </div>
      <div class="quick-cmd">
        <code>phylax stop</code>
        <span>Stops daemon and releases file locks</span>
      </div>
      <div class="quick-cmd">
        <code>phylax status</code>
        <span>Live view: projects, agents, events, blocks</span>
      </div>
    </div>

    <div class="install-badges" data-reveal>
      <span>Runs locally</span>
      <span>No login</span>
      <span>No cloud</span>
      <span>No telemetry</span>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const command = 'irm https://raw.githubusercontent.com/TheUser99-spec/Phylax/main/install.ps1 | iex';
  const triggers = document.querySelectorAll('[data-copy-trigger]');
  const toast = document.querySelector('[data-copy-toast]');

  async function handleCopy() {
    try {
      if (navigator.clipboard?.writeText) {
        await navigator.clipboard.writeText(command);
      } else {
        const textarea = document.createElement('textarea');
        textarea.value = command;
        textarea.setAttribute('readonly', '');
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        textarea.remove();
      }

      toast?.classList.add('visible');
      setTimeout(() => toast?.classList.remove('visible'), 1600);
    } catch {
      toast.textContent = 'Select & copy';
      toast?.classList.add('visible');
      setTimeout(() => {
        toast.textContent = 'Copied';
        toast?.classList.remove('visible');
      }, 1600);
    }
  }

  triggers.forEach((el) => el.addEventListener('click', handleCopy));

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    gsap.fromTo(
      '#install [data-reveal]',
      { opacity: 0, y: 24 },
      { opacity: 1, y: 0, duration: 0.55, ease: 'power3.out', stagger: 0.08, scrollTrigger: { trigger: '#install', start: 'top 76%' } }
    );
  }
</script>
