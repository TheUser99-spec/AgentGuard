---
import '../styles/global.css';
import '../styles/experience.css';

const {
  title = 'Phylax - OS-level protection for AI coding agents',
  description = 'Phylax is a Windows security layer for AI coding agents. Phase 1 user-mode ACL enforcement. Open source, Apache 2.0. Seeking technical review.',
  image = '/og-card.png',
  canonical = '',
  structuredData = '',
} = Astro.props;
---

<!doctype html>
<html lang="en" prefix="og: https://ogp.me/ns#">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f7f5ee" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#101312" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="author" content="Phylax" />
    <meta name="application-name" content="Phylax" />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonical || Astro.url} />
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- Open Graph / Facebook / WhatsApp / Telegram / Discord / iMessage / Slack -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Phylax" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical || Astro.url} />
    <meta property="og:image" content={new URL(image, Astro.url).href} />
    <meta property="og:image:secure_url" content={new URL(image, Astro.url).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content="Phylax - OS-level protection for AI coding agents" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@Phylaxdev" />
    <meta name="twitter:creator" content="@Phylaxdev" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.url).href} />
    <meta name="twitter:image:alt" content="Phylax - OS-level protection for AI coding agents" />

    <!-- Structured Data -->
    {structuredData && <script type="application/ld+json" set:html={structuredData}></script>}

    <!-- Outbound click analytics (local-only, no backend) -->
    <script is:inline>
      (function() {
        var store = (function() {
          try { var d = JSON.parse(localStorage.getItem('_pa') || '{}'); return d && typeof d === 'object' ? d : {}; } catch(e) { return {}; }
        })();
        store._v = store._v || 1;
        if (!store.clicks) store.clicks = {};
        if (!store.sessions) store.sessions = 0;
        store.sessions++;
        var save = function() { try { localStorage.setItem('_pa', JSON.stringify(store)); } catch(e) {} };
        save();
        document.addEventListener('click', function(e) {
          var a = e.target.closest('a'); if (!a) return;
          var href = a.getAttribute('href') || '';
          if (!href || href.startsWith('#') || href.startsWith('/') || href.startsWith(window.location.origin)) return;
          var host = (function(u) { try { return new URL(u, window.location.origin).hostname; } catch(e) { return 'unknown'; } })(href);
          var key = host.replace(/^www\./, '');
          store.clicks[key] = (store.clicks[key] || 0) + 1;
          save();
        });
        window._pa = { stats: function() { try { return JSON.parse(localStorage.getItem('_pa')); } catch(e) { return null; } }, reset: function() { localStorage.removeItem('_pa'); } };
      })();
    </script>
  </head>
  <body>
    <div class="scroll-progress" aria-hidden="true"><span></span></div>
    <slot />
  </body>
</html>

<script>
  import Lenis from 'lenis';
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.documentElement.classList.add('js-ready');

  const progressBar = document.querySelector('.scroll-progress span');
  const navLinks = Array.from(document.querySelectorAll('.nav-links a[href^="#"]'));
  const sections = navLinks
    .map((link) => document.querySelector(link.getAttribute('href')))
    .filter(Boolean);

  function updateProgress() {
    const scrollable = document.documentElement.scrollHeight - window.innerHeight;
    const progress = scrollable > 0 ? window.scrollY / scrollable : 0;
    progressBar?.style.setProperty('transform', `scaleX(${Math.min(1, Math.max(0, progress))})`);
  }

  function updateActiveNav() {
    const offset = window.scrollY + window.innerHeight * 0.32;
    let activeId = '';

    sections.forEach((section) => {
      if (section.offsetTop <= offset) activeId = section.id;
    });

    navLinks.forEach((link) => {
      link.classList.toggle('is-active', Boolean(activeId) && link.getAttribute('href') === `#${activeId}`);
    });
  }

  function updatePageChrome() {
    updateProgress();
    updateActiveNav();
  }

  updatePageChrome();
  window.addEventListener('scroll', () => window.requestAnimationFrame(updatePageChrome), { passive: true });

  if (!reduceMotion) {
    const lenis = new Lenis({
      duration: 1.05,
      lerp: 0.08,
      smoothWheel: true,
      wheelMultiplier: 0.9,
    });

    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add((time) => {
      lenis.raf(time * 1000);
    });
    gsap.ticker.lagSmoothing(0);
  }

  document.addEventListener('astro:after-swap', () => {
    ScrollTrigger.refresh();
  });
</script>
